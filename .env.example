VITE_GROQ_API_KEY=""

# BDAPPS CONFIGURATION
BDAPPS_APP_ID="APP_XXXXXX"
BDAPPS_PASSWORD="your_bdapps_api_password"
BDAPPS_BASE_URL="https://api.bdapps.com"
